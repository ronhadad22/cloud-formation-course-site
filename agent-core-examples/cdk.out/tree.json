httpMethod'),\n                'httpStatusCode': 200,\n                'responseBody': {\n                    'application/json': {\n                        'body': json.dumps({\n                            'location': location,\n                            'temperature': 72,\n                            'conditions': 'Sunny',\n                            'humidity': 45\n                        })\n                    }\n                }\n            }\n        }\n    \n    return {\n        'messageVersion': '1.0',\n        'response': {\n            'actionGroup': action,\n            'apiPath': api_path,\n            'httpStatusCode': 404,\n            'responseBody': {\n                'application/json': {\n                    'body': json.dumps({'error': 'Action not found'})\n                }\n            }\n        }\n    }\n      "},"handler":"index.handler","role":{"Fn::GetAtt":["ActionHandlerServiceRoleC342838F","Arn"]},"runtime":"python3.12"}}},"AllowBedrockInvoke":{"id":"AllowBedrockInvoke","path":"ActionGroupsStack/ActionHandler/AllowBedrockInvoke","constructInfo":{"fqn":"aws-cdk-lib.aws_lambda.CfnPermission","version":"2.233.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Lambda::Permission","aws:cdk:cloudformation:props":{"action":"lambda:InvokeFunction","functionName":{"Fn::GetAtt":["ActionHandlerD0E80DBE","Arn"]},"principal":"bedrock.amazonaws.com","sourceArn":{"Fn::GetAtt":["WeatherAgent","AgentArn"]}}}}}},"WeatherAgent":{"id":"WeatherAgent","path":"ActionGroupsStack/WeatherAgent","constructInfo":{"fqn":"aws-cdk-lib.aws_bedrock.CfnAgent","version":"2.233.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Bedrock::Agent","aws:cdk:cloudformation:props":{"actionGroups":[{"actionGroupName":"weather-actions","actionGroupExecutor":{"lambda":{"Fn::GetAtt":["ActionHandlerD0E80DBE","Arn"]}},"apiSchema":{"payload":"{\"openapi\":\"3.0.0\",\"info\":{\"title\":\"Weather API\",\"version\":\"1.0.0\",\"description\":\"API for getting weather information\"},\"paths\":{\"/get-weather\":{\"get\":{\"summary\":\"Get current weather for a location\",\"description\":\"Returns current weather conditions\",\"operationId\":\"getWeather\",\"parameters\":[{\"name\":\"location\",\"in\":\"query\",\"description\":\"City name or location\",\"required\":true,\"schema\":{\"type\":\"string\"}}],\"responses\":{\"200\":{\"description\":\"Successful response\",\"content\":{\"application/json\":{\"schema\":{\"type\":\"object\",\"properties\":{\"location\":{\"type\":\"string\"},\"temperature\":{\"type\":\"number\"},\"conditions\":{\"type\":\"string\"},\"humidity\":{\"type\":\"number\"}}}}}}}}}}}"},"description":"Actions for retrieving weather information"}],"agentName":"weather-agent-with-actions","agentResourceRoleArn":{"Fn::GetAtt":["AgentRoleF4A42D6B","Arn"]},"foundationModel":"anthropic.claude-3-sonnet-20240229-v1:0","idleSessionTtlInSeconds":600,"instruction":"You are a helpful weather assistant. You can provide weather information for any location.\n      When asked about weather, use the get-weather action to retrieve current conditions."}}},"AgentId":{"id":"AgentId","path":"ActionGroupsStack/AgentId","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.233.0"}},"AgentArn":{"id":"AgentArn","path":"ActionGroupsStack/AgentArn","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.233.0"}},"CDKMetadata":{"id":"CDKMetadata","path":"ActionGroupsStack/CDKMetadata","constructInfo":{"fqn":"constructs.Construct","version":"10.4.4"},"children":{"Default":{"id":"Default","path":"ActionGroupsStack/CDKMetadata/Default","constructInfo":{"fqn":"aws-cdk-lib.CfnResource","version":"2.233.0"}}}},"BootstrapVersion":{"id":"BootstrapVersion","path":"ActionGroupsStack/BootstrapVersion","constructInfo":{"fqn":"aws-cdk-lib.CfnParameter","version":"2.233.0"}},"CheckBootstrapVersion":{"id":"CheckBootstrapVersion","path":"ActionGroupsStack/CheckBootstrapVersion","constructInfo":{"fqn":"aws-cdk-lib.CfnRule","version":"2.233.0"}}}},"Tree":{"id":"